<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="MirClient.Android.Pages.GamePage"
             BackgroundColor="Black"
             NavigationPage.HasNavigationBar="False">

    <Grid>

        <!-- 游戏渲染画布（SkiaSharp） -->
        <skia:SKCanvasView x:Name="GameCanvas"
                           EnableTouchEvents="True"
                           PaintSurface="OnPaintSurface"
                           Touch="OnCanvasTouch" />

        <!-- 左下角虚拟摇杆区域 -->
        <Frame x:Name="JoystickFrame"
               VerticalOptions="End"
               HorizontalOptions="Start"
               WidthRequest="150"
               HeightRequest="150"
               Margin="16,0,0,16"
               BackgroundColor="Transparent"
               BorderColor="Transparent"
               IsClippedToBounds="True">
            <!-- 虚拟摇杆控件通过代码动态添加 -->
        </Frame>

        <!-- 右下角技能按钮区域 -->
        <Grid x:Name="SkillButtonGrid"
              VerticalOptions="End"
              HorizontalOptions="End"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="Auto,Auto"
              ColumnSpacing="8"
              RowSpacing="8"
              Margin="0,0,16,16">

            <!-- 技能按钮 1 -->
            <Button Grid.Row="0" Grid.Column="0"
                    Text="技1"
                    FontSize="12"
                    TextColor="White"
                    BackgroundColor="#884400"
                    BorderColor="#cc6600"
                    BorderWidth="1"
                    CornerRadius="30"
                    WidthRequest="60"
                    HeightRequest="60"
                    Pressed="OnSkillButtonPressed"
                    CommandParameter="1" />

            <!-- 技能按钮 2 -->
            <Button Grid.Row="0" Grid.Column="1"
                    Text="技2"
                    FontSize="12"
                    TextColor="White"
                    BackgroundColor="#004488"
                    BorderColor="#0066cc"
                    BorderWidth="1"
                    CornerRadius="30"
                    WidthRequest="60"
                    HeightRequest="60"
                    Pressed="OnSkillButtonPressed"
                    CommandParameter="2" />

            <!-- 技能按钮 3 -->
            <Button Grid.Row="1" Grid.Column="0"
                    Text="技3"
                    FontSize="12"
                    TextColor="White"
                    BackgroundColor="#008844"
                    BorderColor="#00cc66"
                    BorderWidth="1"
                    CornerRadius="30"
                    WidthRequest="60"
                    HeightRequest="60"
                    Pressed="OnSkillButtonPressed"
                    CommandParameter="3" />

            <!-- 技能按钮 4 -->
            <Button Grid.Row="1" Grid.Column="1"
                    Text="技4"
                    FontSize="12"
                    TextColor="White"
                    BackgroundColor="#660088"
                    BorderColor="#9900cc"
                    BorderWidth="1"
                    CornerRadius="30"
                    WidthRequest="60"
                    HeightRequest="60"
                    Pressed="OnSkillButtonPressed"
                    CommandParameter="4" />
        </Grid>

    </Grid>

</ContentPage>
