<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- 主色调：游戏金黄色 -->
    <Color x:Key="Primary">#e8c170</Color>
    <Color x:Key="PrimaryDark">#c9a050</Color>
    <Color x:Key="PrimaryDarkText">#1a1a2e</Color>

    <!-- 背景色 -->
    <Color x:Key="PageBackgroundColor">#1a1a2e</Color>
    <Color x:Key="CardBackgroundColor">#252540</Color>

    <!-- 文字颜色 -->
    <Color x:Key="TextPrimary">#e8e8f0</Color>
    <Color x:Key="TextSecondary">#aaaacc</Color>
    <Color x:Key="TextMuted">#666688</Color>

    <!-- 边框颜色 -->
    <Color x:Key="BorderColor">#444466</Color>

    <!-- 错误颜色 -->
    <Color x:Key="ErrorColor">#ee6666</Color>

    <!-- 成功颜色 -->
    <Color x:Key="SuccessColor">#44ee88</Color>

</ResourceDictionary>
