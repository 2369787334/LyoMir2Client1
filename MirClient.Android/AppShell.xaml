<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:MirClient.Android.Pages"
       x:Class="MirClient.Android.AppShell"
       Shell.FlyoutBehavior="Disabled">

    <!-- 启动流程：LoadingPage → LoginPage → GamePage -->
    <ShellContent
        Title="加载中"
        ContentTemplate="{DataTemplate pages:LoadingPage}"
        Route="LoadingPage" />

    <ShellContent
        Title="登录"
        ContentTemplate="{DataTemplate pages:LoginPage}"
        Route="LoginPage" />

    <ShellContent
        Title="游戏"
        ContentTemplate="{DataTemplate pages:GamePage}"
        Route="GamePage" />

    <ShellContent
        Title="设置"
        ContentTemplate="{DataTemplate pages:SettingsPage}"
        Route="SettingsPage" />

</Shell>
